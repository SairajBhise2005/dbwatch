# ─────────────────────────────────────────────────────────────
# DBWatch backend configuration
# Copy this file to `.env` and fill in real values.
# `.env` is gitignored — never commit real credentials.
# ─────────────────────────────────────────────────────────────

# --- Database connection (monitoring / read-only role) ---
# When the backend runs ON the EC2 instance (Docker deployment),
# use the host's IP as seen from the container. For docker-compose
# with network_mode host or host.docker.internal, see README.
DB_HOST=127.0.0.1
DB_PORT=5432
DB_USER=dbwatch
DB_PASSWORD=change-me-monitoring-password
DB_NAME=internship_jusdb

# --- Admin connection (used later by SQL editor + backups) ---
# Kept separate so monitoring stays strictly read-only.
DB_ADMIN_USER=postgres
DB_ADMIN_PASSWORD=your-admin-password-here

# --- SSL ---
# false when connecting over localhost on EC2.
# true (with rejectUnauthorized off) when connecting to a remote DB.
DB_SSL=false

# --- Private RDS via bastion (optional) ---
# Set these ONLY when the backend must reach a private RDS through a
# jump host. When set, the pools tunnel through the bastion to
# DB_HOST:DB_PORT over a local forwarded port. Leave blank for a
# public / in-VPC RDS (direct connection).
#SSH_HOST=bastion.example.com
#SSH_PORT=22
#SSH_USER=ec2-user
#SSH_PRIVATE_KEY_PATH=/app/bastion_key.pem
#SSH_KEY_PASSPHRASE=
#SSH_LOCAL_PORT=6543

# --- Backups (used in Stage 4) ---
BACKUP_DIR=./backups
# Retention: keep the newest N backups and drop any older than D days.
# Runs after each successful backup. Set to 0 to disable a limit.
BACKUP_KEEP_COUNT=10
BACKUP_KEEP_DAYS=30

# --- Web app auth (single shared password, per plan) ---
DASHBOARD_PASSWORD=change-me-dashboard-password

# --- AWS (RDS + CloudWatch monitoring) ---
# Region of the RDS instance, and the DB instance identifier (the name
# you gave it, e.g. dbwatch-rds). Credentials come from the EC2 instance's
# attached IAM role (no keys here). Leave blank to disable AWS features.
AWS_REGION=
RDS_INSTANCE_ID=

# --- AI features (Google Gemini) ---
# Backend-only key for AI query optimization + diagnostic advice.
# Leave blank to disable the AI features (they degrade gracefully).
GEMINI_API_KEY=
# Optional model override (default: gemini-2.0-flash)
GEMINI_MODEL=

# --- Server ---
PORT=3001
# Comma-separated list of allowed origins for CORS.
# In Docker (frontend served by nginx same-origin) this can stay as-is.
CORS_ORIGIN=http://localhost:5173
